server {
    listen 80;
    server_name ota.zvolta.com;
    
    # Redirect all HTTP traffic to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name ota.zvolta.com;

    ssl_certificate /etc/letsencrypt/live/ota.zvolta.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ota.zvolta.com/privkey.pem;
    
    # SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 2M;
    
    client_body_timeout 60s;
    proxy_read_timeout 60s;

    location / {
        include proxy_params;
        proxy_pass http://unix:/home/esp32ota-backend/esp32ota.sock;
    }
}
